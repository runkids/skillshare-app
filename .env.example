# Skillshare App OAuth Configuration
# Copy this file to .env and fill in your credentials

# Vercel OAuth (from https://vercel.com/dashboard -> Integrations -> Integrations Console)
SKILLSHARE_VERCEL_CLIENT_ID=oac_xxxxxxxxxx
SKILLSHARE_VERCEL_CLIENT_SECRET=xxxxxxxxxx

# Netlify OAuth (from https://app.netlify.com/user/applications)
SKILLSHARE_NETLIFY_CLIENT_ID=xxxxxxxxxx
